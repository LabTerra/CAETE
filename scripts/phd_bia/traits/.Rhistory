library(zoo)
# Ensure ordered by Source and run_year
wd_means <- wd_means %>%
arrange(Source, run_year)
# 1) 5-year rolling mean (right-aligned). NA for first 4 points
wd_means <- wd_means %>%
group_by(Source) %>%
mutate(wd_roll5 = zoo::rollapply(
data = weighted_mean_wd, width = 5, FUN = mean,
align = "right", fill = NA, na.rm = TRUE
)) %>%
ungroup()
# 2) Standardized anomalies vs. a baseline (run_year 1–10)
wd_baseline <- wd_means %>%
filter(run_year <= 10) %>%
group_by(Source) %>%
summarise(wd_base_mean = mean(weighted_mean_wd, na.rm = TRUE),
wd_base_sd   = sd(weighted_mean_wd,   na.rm = TRUE),
.groups = "drop")
wd_means <- wd_means %>%
left_join(wd_baseline, by = "Source") %>%
mutate(wd_anom_std = (weighted_mean_wd - wd_base_mean) / wd_base_sd)
# 3) Plot: raw series + rolling mean + linear trend (dotted)
p_wd_ts <- ggplot(wd_means, aes(run_year, weighted_mean_wd, color = Source)) +
geom_line(linewidth = 1.0, alpha = 0.9, na.rm = TRUE) +
geom_line(aes(y = wd_roll5), linewidth = 1.2, linetype = "longdash", na.rm = TRUE) +
geom_smooth(method = "lm", se = FALSE, linetype = "dotted", linewidth = 0.9) +
scale_color_manual(values = cols) +
scale_x_continuous(breaks = seq(1, max(wd_means$run_year, na.rm = TRUE), by = 5)) +
labs(x = "Running year",
y = expression("WD weighted mean (g/cm"^3*")"),
color = "Scenario",
title = "WD: raw (solid), 5-year rolling mean (long-dash), linear trend (dotted)") +
theme_minimal(base_size = 16) +
theme(legend.position = "bottom")
# 4) Plot standardized anomalies (z-scores relative to years 1–10)
p_wd_anom <- ggplot(wd_means, aes(run_year, wd_anom_std, color = Source)) +
geom_hline(yintercept = 0, linewidth = 0.3) +
geom_line(linewidth = 1.0, na.rm = TRUE) +
geom_smooth(method = "lm", se = FALSE, linetype = "dotted", linewidth = 0.9) +
scale_color_manual(values = cols) +
scale_x_continuous(breaks = seq(1, max(wd_means$run_year, na.rm = TRUE), by = 5)) +
labs(x = "Running year", y = "Standardized anomaly (z)", color = "Scenario",
title = "WD anomalies vs. baseline (years 1–10)") +
theme_minimal(base_size = 16) +
theme(legend.position = "bottom")
p_wd_ts
p_wd_anom
